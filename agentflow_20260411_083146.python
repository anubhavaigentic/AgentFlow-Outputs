"""
Module for general-purpose utility functions and a sample application scaffold.

This module provides a starting point for developer requests where specific
requirements have not yet been clarified. It includes common patterns such as
data processing, configuration handling, logging setup, and a basic CLI
interface.
"""

import argparse
import json
import logging
import sys
from dataclasses import dataclass, field
from pathlib import Path
from typing import Any


# ---------------------------------------------------------------------------
# Logging configuration
# ---------------------------------------------------------------------------

def setup_logging(level: str = "INFO") -> logging.Logger:
    """Configure and return a module-level logger.

    Args:
        level: A string representing the desired logging level
               (e.g., "DEBUG", "INFO", "WARNING", "ERROR").

    Returns:
        A configured :class:`logging.Logger` instance.
    """
    numeric_level = getattr(logging, level.upper(), logging.INFO)
    logging.basicConfig(
        format="%(asctime)s | %(levelname)-8s | %(name)s | %(message)s",
        datefmt="%Y-%m-%dT%H:%M:%S",
        level=numeric_level,
        stream=sys.stdout,
    )
    return logging.getLogger(__name__)


logger = setup_logging()


# ---------------------------------------------------------------------------
# Configuration
# ---------------------------------------------------------------------------

@dataclass
class AppConfig:
    """Application configuration loaded from a JSON file or defaults.

    Attributes:
        input_path: Path to the input data file.
        output_path: Path where processed results will be written.
        debug: Enable verbose debug output.
        extra: Arbitrary additional settings for future extensibility.
    """

    input_path: Path = Path("input.json")
    output_path: Path = Path("output.json")
    debug: bool = False
    extra: dict[str, Any] = field(default_factory=dict)

    @classmethod
    def from_file(cls, config_path: Path) -> "AppConfig":
        """Load configuration from a JSON file.

        Args:
            config_path: Path to the JSON configuration file.

        Returns:
            An :class:`AppConfig` instance populated with values from the file.

        Raises:
            FileNotFoundError: If *config_path* does not exist.
            ValueError: If the JSON is malformed.
        """
        if not config_path.exists():
            raise FileNotFoundError(f"Config file not found: {config_path}")

        with config_path.open("r", encoding="utf-8") as fh:
            raw: dict[str, Any] = json.load(fh)

        return cls(
            input_path=Path(raw.get("input_path", "input.json")),
            output_path=Path(raw.get("output_path", "output.json")),
            debug=bool(raw.get("debug", False)),
            extra={k: v for k, v in raw.items()
                   if k not in {"input_path", "output_path", "debug"}},
        )


# ---------------------------------------------------------------------------
# Core processing logic
# ---------------------------------------------------------------------------

def load_data(path: Path) -> list[dict[str, Any]]:
    """Load a JSON array from *path*.

    Args:
        path: Path to a JSON file that contains a top-level list.

    Returns:
        A list of dictionaries representing the loaded records.

    Raises:
        FileNotFoundError: If *path* does not exist.
        TypeError: If the JSON root is not a list.
    """
    if not path.exists():
        raise FileNotFoundError(f"Input file not found: {path}")

    with path.open("r", encoding="utf-8") as fh:
        data = json.load(fh)

    if not isinstance(data, list):
        raise TypeError(
            f"Expected a JSON array at the top level of {path}, "
            f"got {type(data).__name__!r} instead."
        )

    logger.debug("Loaded %d records from %s", len(data), path)
    return data


def process_records(
    records: list[dict[str, Any]],
    *,
    filter_key: str | None = None,
    filter_value: Any = None,
) -> list[dict[str, Any]]:
    """Process and optionally filter a list of records.

    Each record is inspected; if *filter_key* and *filter_value* are provided,
    only records where ``record[filter_key] == filter_value`` are retained.
    A ``_processed`` boolean flag is added to each surviving record.

    Args:
        records: The input list of record dictionaries.
        filter_key: Optional key to filter records on.
        filter_value: The value that *filter_key* must equal for a record
                      to be retained. Ignored when *filter_key* is ``None``.

    Returns:
        A new list of processed (and potentially filtered) record dictionaries.
    """
    results: list[dict[str, Any]] = []

    for record in records:
        # Apply optional key-value filter
        if filter_key is not None and record.get(filter_key) != filter_value:
            logger.debug("Skipping record (filter mismatch): %s", record)
            continue

        # Mark the record as processed and append a copy to avoid mutation
        processed = {**record, "_processed": True}
        results.append(processed)

    logger.info(
        "Processing complete: %d/%d records retained.",
        len(results),
        len(records),
    )
    return results


def save_data(data: list[dict[str, Any]], path: Path) -> None:
    """Serialize *data* to a pretty-printed JSON file at *path*.

    Args:
        data: The list of records to write.
        path: Destination file path. Parent directories will be created
              if they do not already exist.
    """
    # Ensure the parent directory exists
    path.parent.mkdir(parents=True, exist_ok=True)

    with path.open("w", encoding="utf-8") as fh:
        json.dump(data, fh, indent=2, ensure_ascii=False)

    logger.info("Results written to %s (%d records).", path, len(data))


# ---------------------------------------------------------------------------
# CLI
# ---------------------------------------------------------------------------

def build_arg_parser() -> argparse.ArgumentParser:
    """Build and return the CLI argument parser.

    Returns:
        A configured :class:`argparse.ArgumentParser` instance.
    """
    parser = argparse.ArgumentParser(
        description="General-purpose data processing scaffold.",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    parser.add_argument(
        "--config",
        type=Path,
        default=None,
        help="Path to a JSON configuration file.",
    )
    parser.add_argument(
        "--input",
        type=Path,
        default=None,
        help="Override the input data file path.",
    )
    parser.add_argument(
        "--output",
        type=Path,
        default=None,
        help="Override the output data file path.",
    )
    parser.add_argument(
        "--filter-key",
        default=None,
        help="Record key to filter on.",
    )
    parser.add_argument(
        "--filter-value",
        default=None,
        help="Value that --filter-key must equal for a record to be kept.",
    )
    parser.add_argument(
        "--debug",
        action="store_true",
        help="Enable DEBUG-level logging.",
    )
    return parser


def main(argv: list[str] | None = None) -> int:
    """Application entry point.

    Parses CLI arguments, loads configuration, and orchestrates the
    load → process → save pipeline.

    Args:
        argv: Argument list to parse. Defaults to ``sys.argv[1:]`` when
              ``None``.

    Returns:
        An integer exit code (0 for success, non-zero for failure).
    """
    parser = build_arg_parser()
    args = parser.parse_args(argv)

    # Reconfigure logging if --debug was requested before config is loaded
    if args.debug:
        setup_logging("DEBUG")

    # Build config: start with defaults, optionally override from file
    if args.config:
        try:
            config = AppConfig.from_file(args.config)
        except (FileNotFoundError, ValueError, json.JSONDecodeError) as exc:
            logger.error("Failed to load config: %s", exc)
            return 1
    else:
        config = AppConfig()

    # CLI flags take precedence over the config file
    if args.input:
        config.input_path = args.input
    if args.output:
        config.output_path = args.output
    if args.debug:
        config.debug = True

    # Apply debug flag from resolved config
    if config.debug:
        setup_logging("DEBUG")

    logger.debug("Effective configuration: %s", config)

    # --- Load ---
    try:
        records = load_data(config.input_path)
    except (FileNotFoundError, TypeError, json.JSONDecodeError) as exc:
        logger.error("Error loading data: %s", exc)
        return 1

    # --- Process ---
    processed = process_records(
        records,
        filter_key=args.filter_key,
        filter_value=args.filter_value,
    )

    # --- Save ---
    try:
        save_data(processed, config.output_path)
    except OSError as exc:
        logger.error("Error saving results: %s", exc)
        return 1

    return 0


if __name__ == "__main__":
    sys.exit(main())